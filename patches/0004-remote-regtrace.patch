 static void (*pInterceptReadTable[0x8000])(void);	/* Table with read access handlers */
@@ -55,6 +56,44 @@ uint32_t IoAccessCurrentAddress;			/* Current byte address while handling WORD a
 static int nBusErrorAccesses;				/* Needed to count bus error accesses */
 
 
+/* --- Talos B2 (F-220): per-frame hardware-register-write trace ------------- */
+/* See ioMem.h. Off by default; RegTrace_Add early-returns when disabled and    */
+/* only writes a host-side buffer, so it never perturbs emulation.              */
+#define REG_TRACE_MAX		65536
+#define TALOS_IS_VIDEO_REG(a)	( ((a) & 0xffff00) == 0x00ff8200 )
+static REG_TRACE_ENTRY	RegTrace[REG_TRACE_MAX];
+static uint32_t		RegTraceCount;
+static uint32_t		RegTraceLimit = REG_TRACE_MAX;
+static bool		RegTraceEnabled;
+
+static void RegTrace_Add ( uint32_t addr , uint16_t value )
+{
+	int frameCyc, hbl, lineCyc;
+	if ( !RegTraceEnabled || RegTraceCount >= RegTraceLimit )
+		return;
+	Video_GetPosition ( &frameCyc , &hbl , &lineCyc );
+	RegTrace[RegTraceCount].addr      = addr;
+	RegTrace[RegTraceCount].value     = value;
+	RegTrace[RegTraceCount].scanline  = (int16_t)hbl;
+	RegTrace[RegTraceCount].lineCycle = (int16_t)lineCyc;
+	RegTraceCount++;
+}
+
+void RegTrace_SetEnabled ( bool on , uint32_t limit )
+{
+	RegTraceEnabled = on;
+	if ( on )
+	{
+		RegTraceCount = 0;			/* fresh capture on enable */
+		RegTraceLimit = ( limit == 0 || limit > REG_TRACE_MAX ) ? REG_TRACE_MAX : limit;
+	}
+}
+bool RegTrace_IsEnabled ( void )		{ return RegTraceEnabled; }
+void RegTrace_Clear ( void )			{ RegTraceCount = 0; }
+uint32_t RegTrace_GetCount ( void )		{ return RegTraceCount; }
+const REG_TRACE_ENTRY *RegTrace_GetEntries ( void )	{ return RegTrace; }
+
+
 /*
   Heuristics for better cycle accuracy when "cycle exact mode" is not used
 
@@ -656,6 +695,7 @@ void REGPARAM3 IoMem_bput(uaecptr addr, uae_u32 val)
 	nBusErrorAccesses = 0;
 
 	IoMem[addr] = val;
+	if (TALOS_IS_VIDEO_REG(addr)) RegTrace_Add(addr, val & 0xff);   /* Talos B2 (F-220) */
 
 	IoAccessCurrentAddress = addr;
 	pInterceptWriteTable[addr-0xff8000]();        /* Call handler */
@@ -712,6 +752,7 @@ void REGPARAM3 IoMem_wput(uaecptr addr, uae_u32 val)
 	nBusErrorAccesses = 0;
 
 	IoMem_WriteWord(addr, val);
+	if (TALOS_IS_VIDEO_REG(addr)) RegTrace_Add(addr, val & 0xffff);   /* Talos B2 (F-220) */
 	idx = addr - 0xff8000;
 
 	IoAccessCurrentAddress = addr;
@@ -775,6 +816,10 @@ void REGPARAM3 IoMem_lput(uaecptr addr, uae_u32 val)
 	nBusErrorAccesses = 0;
 
 	IoMem_WriteLong(addr, val);
+	if (TALOS_IS_VIDEO_REG(addr)) {                                  /* Talos B2 (F-220): long = 2 words */
+		RegTrace_Add(addr, (val >> 16) & 0xffff);
+		RegTrace_Add(addr + 2, val & 0xffff);
+	}
 	idx = addr - 0xff8000;
 
