+/* Talos B2 (F-220): per-frame hardware-register-write trace. Records writes to
+ * the video/palette/sync/scroll registers ($ff8200-$ff82ff) with their beam
+ * position, so the client can plot a whole frame's hardware activity. Opt-in and
+ * off by default (Add early-returns when off), so it never perturbs emulation. */
+typedef struct {
+	uint32_t	addr;		/* register address */
+	uint16_t	value;		/* value written */
+	int16_t		scanline;	/* HBL at the write */
+	int16_t		lineCycle;	/* LineCycles at the write */
+} REG_TRACE_ENTRY;
+extern void			RegTrace_SetEnabled ( bool on , uint32_t limit );
+extern bool			RegTrace_IsEnabled ( void );
+extern void			RegTrace_Clear ( void );
+extern uint32_t			RegTrace_GetCount ( void );
+extern const REG_TRACE_ENTRY *	RegTrace_GetEntries ( void );
 extern uint32_t IoAccessCurrentAddress;
 
 extern int	IoAccessInstrCount;
