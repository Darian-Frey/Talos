+/**
+ * Talos B2 (F-220): per-frame hardware-register-write trace. Same opt-in shape as
+ * blittrace, but taps writes to the video registers ($ff8200-$ff82ff) and stamps
+ * each with its beam position, so the client can plot a whole frame's activity.
+ *
+ *   regtrace on [N]   enable + clear; cap at N entries (hex; 0/absent = full) -> OK
+ *   regtrace off      disable                                                 -> OK
+ *   regtrace clear    clear without disabling                                 -> OK
+ *   regtrace          dump: OK <sep> <count> then per entry:
+ *                     addr <sep> scanline <sep> lineCycle <sep> value (all hex)
+ */
+static int RemoteDebug_regtrace(int nArgc, char *psArgs[], RemoteDebugState* state)
+{
+	if (nArgc >= 2)
+	{
+		if (strcmp(psArgs[1], "on") == 0)
+		{
+			uint32_t limit = 0;
+			if (nArgc >= 3)
+				read_hex32_value(psArgs[2], &limit);
+			RegTrace_SetEnabled(true, limit);
+		}
+		else if (strcmp(psArgs[1], "off") == 0)
+			RegTrace_SetEnabled(false, 0);
+		else if (strcmp(psArgs[1], "clear") == 0)
+			RegTrace_Clear();
+		else
+			return 1;			/* unknown sub-command */
+		send_str(state, "OK");
+		return 0;
+	}
+
+	const REG_TRACE_ENTRY* entries = RegTrace_GetEntries();
+	uint32_t count = RegTrace_GetCount();
+	send_str(state, "OK");
+	send_sep(state);
+	send_hex(state, count);
+	for (uint32_t i = 0; i < count; ++i)
+	{
+		send_sep(state); send_hex(state, entries[i].addr);
+		send_sep(state); send_hex(state, (uint16_t)entries[i].scanline);
+		send_sep(state); send_hex(state, (uint16_t)entries[i].lineCycle);
+		send_sep(state); send_hex(state, entries[i].value);
+	}
+	return 0;
+}
+
 static const rdbcommand_t remoteDebugCommandList[] = {
